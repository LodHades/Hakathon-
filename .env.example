

# =============================================================================
# APP DB CONF
# =============================================================================

# Credenciales de la base de datos de la app
DB_USER=postgres
DB_PASS=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=data_app




# =============================================================================
# API KEY CONF
# =============================================================================

GOOGLE_API_KEY=your_api_key
GROQ_API_KEY=your_api_key
DEEP_SEEK_API_KEY=your_api_key




# =============================================================================
# MCP DATA SERVER (Pandas + Docling)
# =============================================================================

# stdio: el backend lanza mcp_server como subproceso (recomendado en dev)
# sse:   el backend conecta por HTTP a un mcp_server ya corriendo (docker)
MCP_DATA_TRANSPORT=stdio
MCP_DATA_COMMAND=python
MCP_DATA_URL=http://localhost:8765/sse


# =============================================================================
# ANALYST TARGET DB (Postgres del usuario que el agente analiza)
# =============================================================================

# SQLAlchemy URL completa del Postgres por defecto que el analyst consulta.
# Si se deja vacío, el analyst no expone tools SQL — solo MCP/archivos.
# Local (fuera de docker): apunta a tu Postgres.
# Docker compose: el `docker-compose.yaml` sobreescribe este valor para usar
# `postgres-db:5432/${DB_NAME}` dentro de la red de docker.
DATA_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/data_app


# =============================================================================
# SNOWFLAKE MCP (oficial: Snowflake-Labs/mcp)
# =============================================================================

MCP_SNOWFLAKE_ENABLED=false
MCP_SNOWFLAKE_TRANSPORT=stdio
MCP_SNOWFLAKE_COMMAND=uvx
MCP_SNOWFLAKE_ARGS=mcp-server-snowflake
MCP_SNOWFLAKE_URL=

# Credenciales del MCP de Snowflake (heredadas al subproceso)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=


# =============================================================================
# BIGQUERY MCP (community: mcp-server-bigquery)
# =============================================================================

MCP_BIGQUERY_ENABLED=false
MCP_BIGQUERY_TRANSPORT=stdio
MCP_BIGQUERY_COMMAND=uvx
MCP_BIGQUERY_ARGS=mcp-server-bigquery
MCP_BIGQUERY_URL=

# Credenciales BigQuery (heredadas al subproceso)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=


# =============================================================================
# FRONTEND
# =============================================================================

# En docker-compose el frontend corre en :3000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
