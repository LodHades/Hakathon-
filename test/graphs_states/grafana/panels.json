  {
    "type": "timeseries",
    "gridPos": {
      "x": 0,
      "y": 0,
      "w": 12,
      "h": 8
    },
    "title": "Evolución de las Ventas Mensuales",
    "datasource": {
      "type": "postgres",
      "uid": "pg-db-1"
    },
    "targets": [
      {
        "format": "table",
        "group": [],
        "metricColumn": "none",
        "rawQuery": true,
        "rawSql": "SELECT\n    date_trunc('month', o.order_date)::timestamp AS time,\n    SUM(od.unit_price * od.quantity * (1 - od.discount)) AS monthly_sales\nFROM\n    orders o\nJOIN\n    order_details od ON o.order_id = od.order_id\nGROUP BY\n    date_trunc('month', o.order_date)\nORDER BY\n    time;",
        "refId": "A",
        "select": [
          [
            {
              "params": [
                "value"
              ]
            }
          ]
        ],
        "timeColumn": "time"
      }
    ],
    "options": {},
    "fieldConfig": {
      "defaults": {
        "unit": "currencyUSD"
      },
      "overrides": []
    }
  },
  {
    "type": "barchart",
    "gridPos": {
      "x": 0,
      "y": 0,
      "w": 12,
      "h": 8
    },
    "title": "Top 3 Empleados por Ingresos Generados",
    "datasource": {
      "type": "postgres",
      "uid": "pg-db-1"
    },
    "targets": [
      {
        "format": "table",
        "group": [],
        "metricColumn": "none",
        "rawQuery": true,
        "rawSql": "SELECT\n    e.first_name || ' ' || e.last_name AS employee_name,\n    SUM(od.unit_price * od.quantity * (1 - od.discount)) AS total_revenue\nFROM\n    employees AS e\nJOIN\n    orders AS o ON e.employee_id = o.employee_id\nJOIN\n    order_details AS od ON o.order_id = od.order_id\nGROUP BY\n    e.employee_id, employee_name\nORDER BY\n    total_revenue DESC\nLIMIT 3;",
        "refId": "A",
        "select": [
          [
            {
              "params": [
                "value"
              ]
            }
          ]
        ],
        "timeColumn": "",
        "where": []
      }
    ],
    "options": {
      "showValue": true,
      "orientation": "vertical"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "dollar",
        "custom": {}
      },
      "overrides": []
    }
  },
