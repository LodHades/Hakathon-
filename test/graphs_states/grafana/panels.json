    "title": "Tiempo Promedio de Envío por Transportista",
    "datasource": {
      "type": "postgres",
      "uid": "pg-db-1"
    },
    "targets": [
      {
        "format": "table",
        "group": [],
        "metricColumn": "none",
        "rawQuery": true,
        "rawSql": "SELECT\n    s.company_name,\n    AVG(EXTRACT(EPOCH FROM (o.shipped_date - o.order_date))) / 86400.0 AS average_shipping_time_days\nFROM\n    orders o\nJOIN\n    shippers s ON o.ship_via = s.shipper_id\nWHERE\n    o.shipped_date IS NOT NULL AND o.order_date IS NOT NULL\nGROUP BY\n    s.company_name\nORDER BY\n    average_shipping_time_days ASC;",
        "refId": "A",
        "select": [
          [
            {
              "params": [
                "value"
